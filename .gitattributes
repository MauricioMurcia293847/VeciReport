# =============================================================
# VeciReport - .gitattributes
# Configuracion de GitHub Linguist
# Lenguaje principal: PHP
# =============================================================

# --- Backend: PHP ---
*.php linguist-detectable=true

# --- Estilos: CSS ---
*.css linguist-detectable=true

# --- Scripts: JavaScript ---
*.js linguist-detectable=true

# --- Base de datos: SQL ---
*.sql linguist-detectable=true

# --- Archivos de estructura de carpetas ---
*.gitkeep linguist-detectable=false
