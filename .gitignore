# VeciReport - .gitignore

# --- Credenciales y configuracion local ---
App/config/database.php
App/config/app.php

# --- Configuracion local opcional de Apache en la raiz ---
/.htaccess

# --- Archivos subidos por los usuarios ---
uploads/comprobantes/*
uploads/reportes/*

# Conservar la estructura de carpetas en el repo
!uploads/comprobantes/.gitkeep
!uploads/reportes/.gitkeep
!uploads/.htaccess

# --- Claude Code ---
.claude/

# --- Herramienta de diagnostico (nunca commitear) ---
test_conexion.php

# --- Sistema operativo ---
Thumbs.db
.DS_Store

# --- Logs ---
*.log
